#!/usr/bin/env bash
# ============================================================
# Datacheap
# Mesheryakov&Romanov
# ============================================================
# Beautiful Linux CLI Internet Speed Test
# Ping / Download / Upload
# ============================================================

set -Eeuo pipefail

# ------------------------------------------------------------
# Colors
# ------------------------------------------------------------
RESET=$'\033[0m'
BOLD=$'\033[1m'

RED=$'\033[31m'
GREEN=$'\033[32m'
YELLOW=$'\033[33m'
BLUE=$'\033[34m'
MAGENTA=$'\033[35m'
CYAN=$'\033[36m'

GRAY=$'\033[90m'
BRIGHT_GREEN=$'\033[92m'
BRIGHT_CYAN=$'\033[96m'
BRIGHT_MAGENTA=$'\033[95m'

# ------------------------------------------------------------
# Config (override via env if needed)
# ------------------------------------------------------------
PING_HOST="${PING_HOST:-1.1.1.1}"
DOWNLOAD_URL="${DOWNLOAD_URL:-https://speed.hetzner.de/100MB.bin}"
UPLOAD_URL="${UPLOAD_URL:-https://httpbin.org/post}"
UPLOAD_SIZE_MB="${UPLOAD_SIZE_MB:-10}"
TIMEOUT="${TIMEOUT:-30}"

TMP_DIR=""
UPLOAD_FILE=""

# ------------------------------------------------------------
# Cleanup
# ------------------------------------------------------------
cleanup() {
  [[ -n "${UPLOAD_FILE:-}" && -f "$UPLOAD_FILE" ]] && rm -f "$UPLOAD_FILE"
  [[ -n "${TMP_DIR:-}" && -d "$TMP_DIR" ]] && rm -rf "$TMP_DIR"
}
trap cleanup EXIT

# ------------------------------------------------------------
# Helpers
# ------------------------------------------------------------
color() {
  local c="$1"; shift
  printf "%s%s%s" "$c" "$*" "$RESET"
}

bold() {
  printf "%s%s%s" "$BOLD" "$*" "$RESET"
}

term_width() {
  tput cols 2>/dev/null || echo 72
}

line() {
  printf "%s\n" "$(color "$BRIGHT_CYAN" "$(printf '═%.0s' $(seq 1 "$(term_width)"))")"
}

subline() {
  printf "%s\n" "$(color "$GRAY" "$(printf '─%.0s' $(seq 1 "$(term_width)"))")"
}

center() {
  local text="$1"
  local width
  width="$(term_width)"
  printf "%*s\n" $(( (width + ${#text}) / 2 )) "$text"
}

need_cmd() {
  command -v "$1" >/dev/null 2>&1
}

check_deps() {
  local missing=()
  for c in bash curl awk dd mktemp ping date tr; do
    need_cmd "$c" || missing+=("$c")
  done

  if (( ${#missing[@]} > 0 )); then
    echo "$(color "$RED" "❌ Missing dependencies: ${missing[*]}")"
    exit 1
  fi
}

# ------------------------------------------------------------
# UI
# ------------------------------------------------------------
print_banner() {
  line
  center "$(color "$BRIGHT_MAGENTA" "$(bold "🚀 DATACHEAP • SPEED TEST 🚀")")"
  center "$(color "$BRIGHT_GREEN"  "$(bold "Datacheap")")"
  center "$(color "$YELLOW"        "$(bold "Mesheryakov&Romanov")")"
  center "$(color "$CYAN" "Linux CLI edition")"
  line
  echo
}

print_meta() {
  echo "🖥️  $(bold "System")   : Linux / Bash"
  echo "🌐 $(bold "Mode")     : Ping / Download / Upload"
  echo "🕒 $(bold "Started")  : $(date '+%Y-%m-%d %H:%M:%S')"
  subline
}

# ------------------------------------------------------------
# Network info
# ------------------------------------------------------------
get_ip()       { curl -fsS https://api.ipify.org 2>/dev/null || echo "unknown"; }
get_isp()      { curl -fsS https://ipinfo.io/org 2>/dev/null || echo "unknown"; }
get_location() { curl -fsS https://ipinfo.io/city 2>/dev/null || echo "unknown"; }

print_network() {
  echo "🌍 $(bold "IP")       : $(get_ip)"
  echo "🏢 $(bold "ISP")      : $(get_isp)"
  echo "📍 $(bold "Location") : $(get_location)"
  subline
}

# ------------------------------------------------------------
# Tests
# ------------------------------------------------------------
ping_test() {
  ping -c 4 -W 1 "$PING_HOST" 2>/dev/null \
    | awk -F'/' '/^rtt|^round-trip/ {printf "%.2f", $5}'
}

download_test() {
  local bps
  bps=$(curl -L --output /dev/null --max-time "$TIMEOUT" \
        --write-out "%{speed_download}" "$DOWNLOAD_URL" 2>/dev/null || echo 0)
  awk -v b="$bps" 'BEGIN { printf "%.2f", (b*8)/1000000 }'
}

upload_test() {
  TMP_DIR="$(mktemp -d)"
  UPLOAD_FILE="$TMP_DIR/upload.bin"
  dd if=/dev/zero of="$UPLOAD_FILE" bs=1M count="$UPLOAD_SIZE_MB" status=none

  local bps
  bps=$(curl -X POST --output /dev/null --max-time "$TIMEOUT" \
        --write-out "%{speed_upload}" \
        -F "file=@${UPLOAD_FILE}" "$UPLOAD_URL" 2>/dev/null || echo 0)
  awk -v b="$bps" 'BEGIN { printf "%.2f", (b*8)/1000000 }'
}

# ------------------------------------------------------------
# Results
# ------------------------------------------------------------
result() {
  local ping="$1" down="$2" up="$3"

  echo "📶 $(bold "Ping")     : $(color "$YELLOW" "$ping ms")"
  echo "⬇️  $(bold "Download") : $(color "$GREEN" "$down Mbps")"
  echo "⬆️  $(bold "Upload")   : $(color "$CYAN" "$up Mbps")"
}

footer() {
  subline
  echo "$(color "$BRIGHT_CYAN" "💙 Datacheap • Mesheryakov&Romanov")"
}

# ------------------------------------------------------------
# Main
# ------------------------------------------------------------
main() {
  check_deps
  print_banner
  print_meta
  print_network

  echo "📡 Checking ping..."
  PING_RESULT="$(ping_test)"
  echo "⬇️  Checking download speed..."
  DOWNLOAD_RESULT="$(download_test)"
  echo "⬆️  Checking upload speed..."
  UPLOAD_RESULT="$(upload_test)"

  subline
  result "$PING_RESULT" "$DOWNLOAD_RESULT" "$UPLOAD_RESULT"
  footer
}

main "$@"
