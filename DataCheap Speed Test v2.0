    if $JSON_OUTPUT || $QUIET_MODE; then
        return
    fi
    clear 2>/dev/null || true
    echo "${BOLD}${CYAN}"
    echo '    в•”в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•—'
    echo '    в•‘     в–€в–€в–€в–€в–€в–€в•—  в–€в–€в–€в–€в–€в•— в–€в–€в–€в–€в–€в–€в–€в–€в•— в–€в–€в–€в–€в–€в•—            в•‘'
    echo '    в•‘     в–€в–€в•”в•ђв•ђв–€в–€в•—в–€в–€в•”в•ђв•ђв–€в–€в•—в•љв•ђв•ђв–€в–€в•”в•ђв•ђв•ќв–€в–€в•”в•ђв•ђв–€в–€в•—           в•‘'
    echo '    в•‘     в–€в–€в•‘  в–€в–€в•‘в–€в–€в–€в–€в–€в–€в–€в•‘   в–€в–€в•‘   в–€в–€в–€в–€в–€в–€в–€в•‘           в•‘'
    echo '    в•‘     в–€в–€в•‘  в–€в–€в•‘в–€в–€в•”в•ђв•ђв–€в–€в•‘   в–€в–€в•‘   в–€в–€в•”в•ђв•ђв–€в–€в•‘           в•‘'
    echo '    в•‘     в–€в–€в–€в–€в–€в–€в•”в•ќв–€в–€в•‘  в–€в–€в•‘   в–€в–€в•‘   в–€в–€в•‘  в–€в–€в•‘           в•‘'
    echo '    в•‘     в•љв•ђв•ђв•ђв•ђв•ђв•ќ в•љв•ђв•ќ  в•љв•ђв•ќ   в•љв•ђв•ќ   в•љв•ђв•ќ  в•љв•ђв•ќ           в•‘'
    echo '    в•‘     в–€в–€в–€в–€в–€в–€в–€в•—в–€в–€в–€в–€в–€в–€в•— в–€в–€в–€в–€в–€в–€в–€в•—в–€в–€в–€в–€в–€в–€в–€в•—в–€в–€в–€в–€в–€в–€в•—     в•‘'
    echo '    в•‘     в–€в–€в•”в•ђв•ђв•ђв•ђв•ќв–€в–€в•”в•ђв•ђв–€в–€в•—в–€в–€в•”в•ђв•ђв•ђв•ђв•ќв–€в–€в•”в•ђв•ђв•ђв•ђв•ќв–€в–€в•”в•ђв•ђв–€в–€в•—    в•‘'
    echo '    в•‘     в–€в–€в–€в–€в–€в•—  в–€в–€в–€в–€в–€в–€в•”в•ќв–€в–€в–€в–€в–€в•—  в–€в–€в–€в–€в–€в•—  в–€в–€в–€в–€в–€в–€в•”в•ќ    в•‘'
    echo '    в•‘     в–€в–€в•”в•ђв•ђв•ќ  в–€в–€в•”в•ђв•ђв•ђв•ќ в–€в–€в•”в•ђв•ђв•ќ  в–€в–€в•”в•ђв•ђв•ќ  в–€в–€в•”в•ђв•ђв–€в–€в•—    в•‘'
    echo '    в•‘     в–€в–€в–€в–€в–€в–€в–€в•—в–€в–€в•‘     в–€в–€в–€в–€в–€в–€в–€в•—в–€в–€в–€в–€в–€в–€в–€в•—в–€в–€в•‘  в–€в–€в•‘    в•‘'
    echo '    в•‘     в•љв•ђв•ђв•ђв•ђв•ђв•ђв•ќв•љв•ђв•ќ     в•љв•ђв•ђв•ђв•ђв•ђв•ђв•ќв•љв•ђв•ђв•ђв•ђв•ђв•ђв•ќв•љв•ђв•ќ  в•љв•ђв•ќ    в•‘'
    echo '    в•‘                                                  в•‘'
    printf "    в•‘${RESET}${BOLD}${YELLOW}%40s${RESET}${CYAN}в•‘\n" "v$VERSION"
    printf "    в•‘${RESET}${DIM}%40s${RESET}${CYAN}в•‘\n" "Mescheryakov & Romanov"
    echo '    в•љв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ќ'
    echo "${RESET}"
    echo ""
}

print_progress_bar() {
    local current=$1
    local total=$2
    local width=40
    local percentage=0
    
    if [ "$total" -gt 0 ]; then
        percentage=$((current * 100 / total))
    fi
    
    local filled=$((current * width / total))
    
    printf "\r  ${CYAN}[${RESET}"
    for ((i=0; i<filled; i++)); do printf "${GREEN}в–€${RESET}"; done
    for ((i=filled; i<width; i++)); do printf "${DIM}в–‘${RESET}"; done
    printf "${CYAN}]${RESET} ${BOLD}%3d%%${RESET}" "$percentage"
}

spinner() {
    local pid=$1
    local msg="$2"
    local spin='вЈѕвЈЅвЈ»вўївЎївЈџвЈЇвЈ·'
    
    if $JSON_OUTPUT || $QUIET_MODE; then
        wait "$pid" 2>/dev/null
        return
    fi
    
    local i=0
    while kill -0 "$pid" 2>/dev/null; do
        printf "\r  ${CYAN}${spin:$((i % 8)):1}${RESET} ${msg}... "
        i=$((i + 1))
        sleep 0.1
    done
    wait "$pid" 2>/dev/null
    printf "\r  ${GREEN}вњ“${RESET} ${msg}... ${GREEN}Done${RESET}  \n"
}

# =============================================================================
# CORE FUNCTIONS
# =============================================================================

fetch_probes() {
    debug_log "Fetching probes from Yandex API"
    
    TMPDIR_ST=$(mktemp -d "/tmp/datacheap.XXXXXX" 2>/dev/null || echo "")
    if [[ -z "$TMPDIR_ST" ]] || [[ ! -d "$TMPDIR_ST" ]]; then
        TMPDIR_ST="/tmp/datacheap.$$"
        mkdir -p "$TMPDIR_ST"
    fi
    
    local raw
    raw=$(curl -s --max-time 10 \
        -H "User-Agent: $UA" \
        -H "Referer: https://yandex.ru/internet/" \
        -H "Accept: application/json" \
        "$PROBES_API" 2>/dev/null)
    
    if [[ -z "$raw" ]]; then
        echo "${RED}Failed to fetch probe servers from Yandex${RESET}" >&2
        exit 1
    fi
    
    echo "$raw" > "$TMPDIR_ST/probes.json"
    
    # Parse JSON with Python
    TMPDIR_ST="$TMPDIR_ST" python3 << 'PYEOF' 2>/dev/null
import json, os, sys

td = os.environ["TMPDIR_ST"]

try:
    with open(f"{td}/probes.json") as f:
        d = json.load(f)
    
    # Save ping URLs
    with open(f"{td}/ping_urls", "w") as f:
        for p in d.get("latency", {}).get("probes", []):
            f.write(p["url"] + "\n")
    
    # Save download URLs (50mb files)
    with open(f"{td}/download_urls", "w") as f:
        for p in d.get("download", {}).get("probes", []):
            url = p["url"]
            if "50mb" in url:
                f.write(url + "\n")
    
    # Save upload URLs
    with open(f"{td}/upload_urls", "w") as f:
        for p in d.get("upload", {}).get("probes", []):
            url = p["url"]
            if "timeout" not in url:
                f.write(url + "\n")
    
    # Save server list
    servers = set()
    for section in ["latency", "download", "upload"]:
        for p in d.get(section, {}).get("probes", []):
            url = p.get("url", "")
            if url:
                host = url.split("/")[2]
                servers.add(host)
    
    with open(f"{td}/servers", "w") as f:
        for s in sorted(servers):
            f.write(s + "\n")
    
    # Save for caching
    cache_dir = os.path.expanduser("~/.config/datacheap-speedtest/cache")
    os.makedirs(cache_dir, exist_ok=True)
    with open(f"{cache_dir}/servers.json", "w") as f:
        json.dump(list(servers), f)
        
except Exception as e:
    sys.stderr.write(f"Python error: {e}\n")
    sys.exit(1)
PYEOF
    
    local server_count
    server_count=$(wc -l < "$TMPDIR_ST/servers" | tr -d ' ')
    
    if ! $JSON_OUTPUT && ! $QUIET_MODE; then
        echo -e "  ${DIM}Found ${BOLD}${server_count}${DIM} Yandex CDN nodes${RESET}"
        if [[ -n "$SELECTED_SERVER" ]]; then
            echo -e "  ${DIM}Selected: ${CYAN}$(sed -n "${SELECTED_SERVER}p" "$TMPDIR_ST/servers")${RESET}"
        fi
    fi
    
    debug_log "Servers: $(cat "$TMPDIR_ST/servers" | tr '\n' ' ')"
}

get_connection_info() {
    debug_log "Getting connection info"
    
    local ipv4 ipv6 info parsed city region country org
    
    ipv4=$(curl -s --max-time 5 -H "User-Agent: $UA" "$IPV4_API" 2>/dev/null | tr -d '"' || echo "N/A")
    ipv6=$(curl -s --max-time 3 -6 -H "User-Agent: $UA" "$IPV6_API" 2>/dev/null | tr -d '"' || echo "")
    info=$(curl -s --max-time 5 "https://ipinfo.io/${ipv4}/json" 2>/dev/null || echo '{}')
    
    parsed=$(echo "$info" | python3 -c "
import json, sys
try:
    d = json.load(sys.stdin)
    print(d.get('city','') + '|' + d.get('region','') + '|' + d.get('country','') + '|' + d.get('org',''))
except:
    print('|||')
" 2>/dev/null || echo "|||")
    
    IFS='|' read -r city region country org <<< "$parsed"
    
    CONN_INFO_IPV4="$ipv4"
    CONN_INFO_IPV6="$ipv6"
    CONN_INFO_CITY="$city"
    CONN_INFO_REGION="$region"
    CONN_INFO_COUNTRY="$country"
    CONN_INFO_ORG="$org"
}

print_connection_info() {
    if $JSON_OUTPUT || $QUIET_MODE; then
        return
    fi
    
    echo ""
    echo -e "  ${BOLD}${CYAN}в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ${RESET}"
    echo -e "  ${BOLD}CONNECTION INFO${RESET}"
    echo -e "  ${DIM}в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ${RESET}"
    echo -e "  ${DIM}IPv4:${RESET}      ${GREEN}${CONN_INFO_IPV4:-N/A}${RESET}"
    
    if [[ -n "${CONN_INFO_IPV6:-}" ]]; then
        echo -e "  ${DIM}IPv6:${RESET}      ${CYAN}${CONN_INFO_IPV6}${RESET}"
    else
        echo -e "  ${DIM}IPv6:${RESET}      ${DIM}not available${RESET}"
    fi
    
    [[ -n "${CONN_INFO_ORG:-}" ]] && echo -e "  ${DIM}ISP:${RESET}       ${YELLOW}${CONN_INFO_ORG}${RESET}"
    [[ -n "${CONN_INFO_CITY:-}" ]] && echo -e "  ${DIM}Location:${RESET}  ${WHITE}${CONN_INFO_CITY}${CONN_INFO_REGION:+, $CONN_INFO_REGION}${CONN_INFO_COUNTRY:+, $CONN_INFO_COUNTRY}${RESET}"
    echo -e "  ${CYAN}в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ${RESET}"
    echo ""
}

measure_ping() {
    debug_log "Measuring ping"
    
    local results=()
    local ping_urls_file="$TMPDIR_ST/ping_urls"
    
    if [[ ! -f "$ping_urls_file" ]]; then
        echo "0.00|0.00|0.00|0.00"
        return
    }
    
    while IFS= read -r url; do
        [[ -z "$url" ]] && continue
        
        # Warmup
        curl -s -o /dev/null -I --max-time 5 -H "User-Agent: $UA" "$url" 2>/dev/null || true
        
        for i in $(seq 1 $PING_SAMPLES); do
            local timing
            timing=$(curl -s -o /dev/null -w "%{time_starttransfer} %{time_appconnect}" \
                -I --max-time 5 -H "User-Agent: $UA" -H "Referer: https://yandex.ru/internet/" \
                "$url" 2>/dev/null || echo "0 0")
            
            local ts ta ms
            ts=$(echo "$timing" | awk '{print $1}')
            ta=$(echo "$timing" | awk '{print $2}')
            ms=$(echo "($ts - $ta) * 1000" | bc 2>/dev/null || echo "0")
            
            if (( $(echo "$ms > 0" | bc -l) )); then
                results+=("$ms")
            fi
        done
    done < "$ping_urls_file"
    
    local count=${#results[@]}
    if [[ $count -eq 0 ]]; then
        echo "0.00|0.00|0.00|0.00"
        return
    fi
    
    # Sort results
    IFS=$'\n' sorted=($(printf '%s\n' "${results[@]}" | sort -g))
    unset IFS
    
    local trim=$((count / 4))
    local total=0 min=999999 max=0 trimmed_count=0
    
    for idx in $(seq $trim $((count - trim - 1))); do
        local val=${sorted[$idx]}
        total=$(echo "$total + $val" | bc)
        trimmed_count=$((trimmed_count + 1))
        
        if (( $(echo "$val < $min" | bc -l) )); then min=$val; fi
        if (( $(echo "$val > $max" | bc -l) )); then max=$val; fi
    done
    
    if [[ $trimmed_count -eq 0 ]]; then
        echo "0.00|0.00|0.00|0.00"
        return
    fi
    
    local avg jitter_sum=0 prev=""
    avg=$(fmt_float "$total / $trimmed_count")
    
    for idx in $(seq $trim $((count - trim - 1))); do
        local val=${sorted[$idx]}
        if [[ -n "$prev" ]]; then
            local diff
            diff=$(echo "$val - $prev" | bc)
            diff=$(echo "${diff#-}" | bc)
            jitter_sum=$(echo "$jitter_sum + $diff" | bc)
        fi
        prev=$val
    done
    
    local jitter
    jitter=$(fmt_float "$jitter_sum / ($trimmed_count - 1)" 2>/dev/null || echo "0.00")
    min=$(fmt_float "$min / 1")
    max=$(fmt_float "$max / 1")
    
    echo "$avg|$min|$max|$jitter"
}

download_stream() {
    local url=$1
    local result_file=$2
    local duration=$3
    
    local output
    output=$(curl -s -o /dev/null -w "%{size_download} %{time_total} %{speed_download}" \
        --max-time "$duration" -H "User-Agent: $UA" -H "Referer: https://yandex.ru/internet/" \
        "$url" 2>/dev/null) || true
    
    echo "${output:-0 0 0}" > "$result_file"
}

measure_download() {
    debug_log "Measuring download"
    
    local idx=0 pids=()
    local download_urls_file="$TMPDIR_ST/download_urls"
    
    if [[ ! -f "$download_urls_file" ]]; then
        echo "0"
        return
    fi
    
    while IFS= read -r url; do
        [[ -z "$url" ]] && continue
        idx=$((idx + 1))
        download_stream "$url" "$TMPDIR_ST/dlspeed_${idx}" "$DOWNLOAD_SECONDS" &
        pids+=($!)
        debug_log "Started download stream $idx"
    done < "$download_urls_file"
    
    for pid in "${pids[@]}"; do
        wait "$pid" 2>/dev/null || true
    done
    
    local total_speed=0 stream_count=0
    for f in "$TMPDIR_ST"/dlspeed_*; do
        [[ -f "$f" ]] || continue
        stream_count=$((stream_count + 1))
        
        local line size time_total computed
        line=$(cat "$f" 2>/dev/null || echo "0 0 0")
        size=$(echo "$line" | awk '{print $1}')
        time_total=$(echo "$line" | awk '{print $2}')
        
        if (( $(echo "$time_total > 0" | bc -l) )); then
            computed=$(echo "$size * 8 / $time_total" | bc)
        else
            computed=0
        fi
        total_speed=$(echo "$total_speed + $computed" | bc)
    done
    
    echo "$total_speed"
}

measure_upload() {
    debug_log "Measuring upload"
    
    local idx=0 pids=()
    local upload_urls_file="$TMPDIR_ST/upload_urls"
    
    if [[ ! -f "$upload_urls_file" ]]; then
        echo "0"
        return
    fi
    
    while IFS= read -r url; do
        [[ -z "$url" ]] && continue
        idx=$((idx + 1))
        
        (
            local data_file="$TMPDIR_ST/upload_data_${idx}"
            dd if=/dev/urandom bs=1M count=10 of="$data_file" 2>/dev/null
            
            local output
            output=$(curl -s -o /dev/null -w "%{size_upload} %{time_total} %{speed_upload}" \
                --max-time "$UPLOAD_SECONDS" -H "User-Agent: $UA" \
                -H "Referer: https://yandex.ru/internet/" \
                -F "file=@$data_file" "$url" 2>/dev/null) || true
            
            echo "${output:-0 0 0}" > "$TMPDIR_ST/ulspeed_${idx}"
        ) &
        pids+=($!)
        debug_log "Started upload stream $idx"
    done < "$upload_urls_file"
    
    for pid in "${pids[@]}"; do
        wait "$pid" 2>/dev/null || true
    done
    
    local total_speed=0 stream_count=0
    for f in "$TMPDIR_ST"/ulspeed_*; do
        [[ -f "$f" ]] || continue
        stream_count=$((stream_count + 1))
        
        local line size time_total computed
        line=$(cat "$f" 2>/dev/null || echo "0 0 0")
        size=$(echo "$line" | awk '{print $1}')
        time_total=$(echo "$line" | awk '{print $2}')
        
        if (( $(echo "$time_total > 0" | bc -l) )); then
            computed=$(echo "$size * 8 / $time_total" | bc)
        else
            computed=0
        fi
        total_speed=$(echo "$total_speed + $computed" | bc)
    done
    
    echo "$total_speed"
}

save_result() {
    local download=$1
    local upload=$2
    local ping_avg=$3
    local ping_min=$4
    local ping_max=$5
    local ping_jitter=$6
    
    local timestamp
    timestamp=$(date +"%Y-%m-%d %H:%M:%S")
    
    # Create header if file doesn't exist
    if [[ ! -f "$HISTORY_FILE" ]]; then
        echo "timestamp,download_bps,upload_bps,ping_avg_ms,ping_min_ms,ping_max_ms,ping_jitter_ms,isp,location" > "$HISTORY_FILE"
    fi
    
    # Clean ISP/location for CSV
    local isp_clean="${CONN_INFO_ORG//,/ }"
    local loc_clean="${CONN_INFO_CITY}${CONN_INFO_REGION:+, $CONN_INFO_REGION}${CONN_INFO_COUNTRY:+, $CONN_INFO_COUNTRY}"
    loc_clean="${loc_clean//,/ }"
    
    echo "$timestamp,$download,$upload,$ping_avg,$ping_min,$ping_max,$ping_jitter,\"$isp_clean\",\"$loc_clean\"" >> "$HISTORY_FILE"
}

show_history() {
    if [[ ! -f "$HISTORY_FILE" ]]; then
        echo "${YELLOW}No test history found${RESET}"
        return
    fi
    
    echo ""
    echo -e "  ${BOLD}${CYAN}в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ${RESET}"
    echo -e "  ${BOLD}TEST HISTORY (last 10)${RESET}"
    echo -e "  ${DIM}в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ${RESET}"
    
    # Use column for pretty formatting, tail for last 10
    tail -n 10 "$HISTORY_FILE" | column -t -s ',' | while IFS= read -r line; do
        echo "  $line"
    done
    
    echo -e "  ${CYAN}в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ${RESET}"
    echo ""
}

output_json() {
    local download=$1
    local upload=$2
    local ping_avg=$3
    local ping_min=$4
    local ping_max=$5
    local ping_jitter=$6
    
    cat << EOF
{
  "version": "$VERSION",
  "timestamp": "$(date -Iseconds)",
  "connection": {
    "ipv4": "${CONN_INFO_IPV4:-null}",
    "ipv6": ${CONN_INFO_IPV6:+\"$CONN_INFO_IPV6\"}${CONN_INFO_IPV6:-null},
    "isp": "${CONN_INFO_ORG:-}",
    "city": "${CONN_INFO_CITY:-}",
    "region": "${CONN_INFO_REGION:-}",
    "country": "${CONN_INFO_COUNTRY:-}"
  },
  "results": {
    "download": {
      "bps": $download,
      "human": "$(format_speed "$download")"
    },
    "upload": {
      "bps": $upload,
      "human": "$(format_speed "$upload")"
    },
    "ping": {
      "average": $ping_avg,
      "minimum": $ping_min,
      "maximum": $ping_max,
      "jitter": $ping_jitter
    }
  }
}
EOF
}

# =============================================================================
# MAIN
# =============================================================================

main() {
    parse_args "$@"
    init_dirs
    
    if $SHOW_HISTORY; then
        show_history
        exit 0
    fi
    
    # Show header
    print_mega_header
    
    # Initial setup
    if ! $QUIET_MODE && ! $JSON_OUTPUT; then
        echo -e "  ${BOLD}Initializing...${RESET}"
    fi
    
    # Check dependencies
    (
        local missing=()
        for cmd in curl bc python3; do
            if ! command -v "$cmd" &>/dev/null; then
                missing+=("$cmd")
            fi
        done
        
        if [[ ${#missing[@]} -gt 0 ]]; then
            echo "${RED}Missing dependencies: ${missing[*]}${RESET}" >&2
            exit 1
        fi
    ) &
    spinner $! "Checking dependencies"
    
    # Fetch probes
    (
        fetch_probes
    ) &
    spinner $! "Fetching probe servers"
    
    # Get connection info
    (
        get_connection_info
    ) &
    spinner $! "Getting connection info"
    
    # Wait for async tasks
    wait
    
    # Show connection info
    print_connection_info
    
    # Measure ping
    (
        PING_RESULT=$(measure_ping)
    ) &
    spinner $! "Measuring ping"
    
    # Parse ping results
    IFS='|' read -r ping_avg ping_min ping_max ping_jitter <<< "$PING_RESULT"
    
    if ! $JSON_OUTPUT && ! $QUIET_MODE; then
        echo ""
        echo -e "  ${BOLD}${CYAN}в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ${RESET}"
        echo -e "  ${BOLD}LATENCY${RESET}"
        echo -e "  ${DIM}в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ${RESET}"
        printf "  ${DIM}Average:${RESET}  ${WHITE}%.2f ms${RESET}\n" "$ping_avg"
        printf "  ${DIM}Min/Max:${RESET}  ${GREEN}%.2f${RESET} / ${RED}%.2f${RESET} ms\n" "$ping_min" "$ping_max"
        printf "  ${DIM}Jitter:${RESET}   ${YELLOW}%.2f${RESET} ms\n" "$ping_jitter"
        echo -e "  ${CYAN}в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ${RESET}"
        echo ""
    fi
    
    # Measure download with progress
    if ! $QUIET_MODE && ! $JSON_OUTPUT; then
        echo -e "  ${BOLD}Testing speed...${RESET}"
        echo -e "  ${DIM}в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ${RESET}"
    fi
    
    DOWNLOAD_SPEED=0
    (
        DOWNLOAD_SPEED=$(measure_download)
    ) &
    spinner $! "Download"
    
    UPLOAD_SPEED=0
    (
        UPLOAD_SPEED=$(measure_upload)
    ) &
    spinner $! "Upload"
    
    wait
    
    # Save to history
    save_result "$DOWNLOAD_SPEED" "$UPLOAD_SPEED" "$ping_avg" "$ping_min" "$ping_max" "$ping_jitter"
    
    # Output results
    if $JSON_OUTPUT; then
        output_json "$DOWNLOAD_SPEED" "$UPLOAD_SPEED" "$ping_avg" "$ping_min" "$ping_max" "$ping_jitter"
    else
        echo ""
        echo -e "  ${BOLD}${CYAN}в•”в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•—${RESET}"
        echo -e "  ${BOLD}${CYAN}в•‘                    RESULTS                        в•‘${RESET}"
        echo -e "  ${BOLD}${CYAN}в• в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•Ј${RESET}"
        
        local download_emoji upload_emoji
        download_emoji=$(get_speed_emoji "$DOWNLOAD_SPEED")
        upload_emoji=$(get_speed_emoji "$UPLOAD_SPEED")
        
        printf "  ${CYAN}в•‘${RESET}  ${download_emoji} ${BOLD}%-8s${RESET}  ${GREEN}%12s${RESET}  %20s${CYAN}в•‘${RESET}\n" \
            "Download" "$(format_speed "$DOWNLOAD_SPEED")" ""
        printf "  ${CYAN}в•‘${RESET}  ${upload_emoji} ${BOLD}%-8s${RESET}  ${YELLOW}%12s${RESET}  %20s${CYAN}в•‘${RESET}\n" \
            "Upload" "$(format_speed "$UPLOAD_SPEED")" ""
        printf "  ${CYAN}в•‘${RESET}  рџЋЇ ${BOLD}%-8s${RESET}  ${WHITE}%7.2f ms${RESET}  ${DIM}(min:%.2f / max:%.2f)${RESET}  ${CYAN}в•‘${RESET}\n" \
            "Ping" "$ping_avg" "$ping_min" "$ping_max"
        printf "  ${CYAN}в•‘${RESET}  рџ“Љ ${BOLD}%-8s${RESET}  ${MAGENTA}%7.2f ms${RESET}  %22s${CYAN}в•‘${RESET}\n" \
            "Jitter" "$ping_jitter" ""
        
        echo -e "  ${BOLD}${CYAN}в•љв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ќ${RESET}"
        echo ""
        
        if [[ -f "$HISTORY_FILE" ]]; then
            local test_count
            test_count=$(wc -l < "$HISTORY_FILE" | tr -d ' ')
            test_count=$((test_count - 1))  # Subtract header
            echo -e "  ${DIM}рџ’ѕ Saved to history (${test_count} tests total)${RESET}"
        fi
        
        # Show random tip
        local tips=(
            "For JSON output use --json"
            "View history with --history"
            "Select server with --server ID"
            "Quiet mode with --quiet"
        )
        local idx=$((RANDOM % ${#tips[@]}))
        echo -e "  ${DIM}рџ’Ў Tip: ${tips[$idx]}${RESET}"
        echo ""
    fi
}

# Run main
main "$@"
