#!/bin/bash

# =============================================================================
# DataPeer Speed Test v2.1
# Mescheryakov & Romanov Industries
# =============================================================================

set -euo pipefail

# =============================================================================
# COLOR SYSTEM
# =============================================================================

if command -v tput >/dev/null 2>&1 && tput setaf 1 >/dev/null 2>&1; then
    RED=$(tput setaf 196)
    GREEN=$(tput setaf 82)
    YELLOW=$(tput setaf 226)
    BLUE=$(tput setaf 39)
    MAGENTA=$(tput setaf 201)
    CYAN=$(tput setaf 51)
    ORANGE=$(tput setaf 208)
    PURPLE=$(tput setaf 129)
    WHITE=$(tput setaf 255)
    GRAY=$(tput setaf 244)
    BOLD=$(tput bold)
    DIM=$(tput dim)
    REVERSE=$(tput rev)
    RESET=$(tput sgr0)
else
    RED='\033[0;31m'; GREEN='\033[0;32m'; YELLOW='\033[1;33m'
    BLUE='\033[0;34m'; MAGENTA='\033[0;35m'; CYAN='\033[0;36m'
    ORANGE='\033[0;33m'; PURPLE='\033[0;35m'; WHITE='\033[1;37m'
    GRAY='\033[1;30m'; BOLD='\033[1m'; DIM='\033[2m'
    REVERSE='\033[7m'; RESET='\033[0m'
fi

# =============================================================================
# CONFIGURATION
# =============================================================================

VERSION="2.1"
CONFIG_DIR="$HOME/.config/datapeer-speedtest"
HISTORY_FILE="$CONFIG_DIR/history.csv"
PING_SAMPLES=10
DOWNLOAD_SECONDS=10
UPLOAD_SECONDS=10

PROBES_API="https://yandex.ru/internet/api/v0/get-probes"
IPV4_API="https://ipv4-internet.yandex.net/api/v0/ip"
IPV6_API="https://ipv6-internet.yandex.net/api/v0/ip"
UA="Mozilla/5.0 (X11; Linux x86_64) AppleWebKit/537.36"

# =============================================================================
# COMMAND LINE ARGUMENTS
# =============================================================================

JSON_OUTPUT=false
QUIET_MODE=false
SHOW_HISTORY=false

while [[ $# -gt 0 ]]; do
    case $1 in
        -j|--json) JSON_OUTPUT=true; shift ;;
        -q|--quiet) QUIET_MODE=true; shift ;;
        -h|--history) SHOW_HISTORY=true; shift ;;
        --help) 
            echo "DataPeer Speed Test v$VERSION"
            echo "Usage: $0 [OPTIONS]"
            echo "  -j, --json     JSON output"
            echo "  -q, --quiet    Quiet mode"
            echo "  -h, --history  Show history"
            exit 0
            ;;
        *) shift ;;
    esac
done

# =============================================================================
# UTILITIES
# =============================================================================

fmt() { printf "%.2f" "$(echo "scale=4; $1" | bc 2>/dev/null || echo "0")"; }

format_speed() {
    local bps=$1
    if (( $(echo "$bps >= 1000000000" | bc -l) )); then echo "$(fmt "$bps / 1000000000") Gbit/s"
    elif (( $(echo "$bps >= 1000000" | bc -l) )); then echo "$(fmt "$bps / 1000000") Mbit/s"
    elif (( $(echo "$bps >= 1000" | bc -l) )); then echo "$(fmt "$bps / 1000") Kbit/s"
    else echo "$(printf "%.0f" "$(echo "$bps" | bc)") bit/s"; fi
}

get_speed_emoji() {
    local speed=$1
    if (( $(echo "$speed >= 1000000000" | bc -l) )); then echo "🚀"
    elif (( $(echo "$speed >= 500000000" | bc -l) )); then echo "⚡"
    elif (( $(echo "$speed >= 100000000" | bc -l) )); then echo "📡"
    else echo "🐢"; fi
}

cleanup() { rm -rf "${TMPDIR_ST:-}" 2>/dev/null; kill $(jobs -p) 2>/dev/null || true; }
trap cleanup EXIT

# =============================================================================
# UI
# =============================================================================

print_header() {
    $JSON_OUTPUT || $QUIET_MODE && return
    echo "${BOLD}${CYAN}"
    echo '    ╔══════════════════════════════════════════════════╗'
    echo '    ║     ██████╗  █████╗ ████████╗ █████╗            ║'
    echo '    ║     ██╔══██╗██╔══██╗╚══██╔══╝██╔══██╗           ║'
    echo '    ║     ██║  ██║███████║   ██║   ███████║           ║'
    echo '    ║     ██║  ██║██╔══██║   ██║   ██╔══██║           ║'
    echo '    ║     ██████╔╝██║  ██║   ██║   ██║  ██║           ║'
    echo '    ║     ╚═════╝ ╚═╝  ╚═╝   ╚═╝   ╚═╝  ╚═╝           ║'
    echo '    ║                                                  ║'
    echo '    ║              D A T A P E E R                    ║'
    echo '    ║              S P E E D   T E S T                 ║'
    echo '    ║                                                  ║'
    printf "    ║${RESET}${BOLD}${YELLOW}%38s${RESET}${CYAN}║\n" "v$VERSION"
    printf "    ║${RESET}${DIM}%38s${RESET}${CYAN}║\n" "Mescheryakov & Romanov"
    echo '    ╚══════════════════════════════════════════════════╝'
    echo "${RESET}"
}

spinner() {
    $JSON_OUTPUT || $QUIET_MODE && { wait "$1" 2>/dev/null; return; }
    local pid=$1 msg="$2" spin='⣾⣽⣻⢿⡿⣟⣯⣷' i=0
    while kill -0 "$pid" 2>/dev/null; do
        printf "\r  ${CYAN}${spin:$((i % 8)):1}${RESET} ${msg}... "
        i=$((i + 1))
        sleep 0.1
    done
    wait "$pid" 2>/dev/null
    printf "\r  ${GREEN}✓${RESET} ${msg}... ${GREEN}Done${RESET}  \n"
}

# =============================================================================
# CORE FUNCTIONS
# =============================================================================

fetch_probes() {
    TMPDIR_ST=$(mktemp -d "/tmp/datapeer.XXXXXX" 2>/dev/null || echo "/tmp/datapeer.$$")
    mkdir -p "$TMPDIR_ST"

    local raw
    raw=$(curl -s --max-time 15 -H "User-Agent: $UA" -H "Accept: application/json" "$PROBES_API" 2>/dev/null)
    
    if [[ -z "$raw" ]]; then
        echo -e "\n${RED}Failed to fetch servers from Yandex. Check your internet connection.${RESET}" >&2
        exit 1
    fi

    echo "$raw" > "$TMPDIR_ST/probes.json"

    python3 << PYEOF 2>/dev/null
import json, os, sys
td = os.environ['TMPDIR_ST']
try:
    with open(f"{td}/probes.json") as f:
        d = json.load(f)
    with open(f"{td}/ping_urls", "w") as f:
        for p in d.get("latency", {}).get("probes", []):
            if p.get("url"): f.write(p["url"] + "\n")
    with open(f"{td}/download_urls", "w") as f:
        for p in d.get("download", {}).get("probes", []):
            if "50mb" in p.get("url", ""):
                f.write(p["url"] + "\n")
    with open(f"{td}/upload_urls", "w") as f:
        for p in d.get("upload", {}).get("probes", []):
            if "timeout" not in p.get("url", ""):
                f.write(p["url"] + "\n")
    sys.exit(0)
except Exception as e:
    sys.stderr.write(f"Python error: {e}\n")
    sys.exit(1)
PYEOF

    if [[ $? -ne 0 ]]; then
        echo -e "\n${RED}Failed to parse server data${RESET}" >&2
        exit 1
    fi
}

get_connection_info() {
    local ipv4 ipv6 info
    ipv4=$(curl -s --max-time 5 "$IPV4_API" 2>/dev/null | tr -d '"' || echo "N/A")
    ipv6=$(curl -s --max-time 3 -6 "$IPV6_API" 2>/dev/null | tr -d '"' || echo "")
    info=$(curl -s --max-time 5 "https://ipinfo.io/${ipv4}/json" 2>/dev/null || echo '{}')

    CONN_IPV4="$ipv4"
    CONN_IPV6="$ipv6"
    CONN_ORG=$(echo "$info" | python3 -c "import json,sys; d=json.load(sys.stdin); print(d.get('org','N/A'))" 2>/dev/null || echo "N/A")
    CONN_CITY=$(echo "$info" | python3 -c "import json,sys; d=json.load(sys.stdin); print(d.get('city','N/A'))" 2>/dev/null || echo "N/A")
    CONN_REGION=$(echo "$info" | python3 -c "import json,sys; d=json.load(sys.stdin); print(d.get('region',''))" 2>/dev/null || echo "")
    CONN_COUNTRY=$(echo "$info" | python3 -c "import json,sys; d=json.load(sys.stdin); print(d.get('country',''))" 2>/dev/null || echo "")
}

measure_ping() {
    local results=()
    while IFS= read -r url; do
        [[ -z "$url" ]] && continue
        for i in $(seq 1 $PING_SAMPLES); do
            local timing
            timing=$(curl -s -o /dev/null -w "%{time_starttransfer} %{time_appconnect}" -I --max-time 5 "$url" 2>/dev/null || echo "0 0")
            local ts=$(echo "$timing" | awk '{print $1}')
            local ta=$(echo "$timing" | awk '{print $2}')
            local ms=$(echo "($ts - $ta) * 1000" | bc 2>/dev/null || echo "0")
            if (( $(echo "$ms > 0" | bc -l) )); then
                results+=("$ms")
            fi
        done
    done < "$TMPDIR_ST/ping_urls"

    local count=${#results[@]}
    if [[ $count -eq 0 ]]; then
        echo "0.00|0.00|0.00|0.00"
        return
    fi

    IFS=$'\n' sorted=($(printf '%s\n' "${results[@]}" | sort -g))
    unset IFS
    local trim=$((count / 4))
    local total=0 min=999999 max=0 trimmed=0

    for idx in $(seq $trim $((count - trim - 1))); do
        local val=${sorted[$idx]}
        total=$(echo "$total + $val" | bc)
        trimmed=$((trimmed + 1))
        (( $(echo "$val < $min" | bc -l) )) && min=$val
        (( $(echo "$val > $max" | bc -l) )) && max=$val
    done

    local avg=$(fmt "$total / $trimmed")
    local jitter=0 prev=""
    for idx in $(seq $trim $((count - trim - 1))); do
        local val=${sorted[$idx]}
        if [[ -n "$prev" ]]; then
            local diff=$(echo "$val - $prev" | bc)
            diff=$(echo "${diff#-}" | bc)
            jitter=$(echo "$jitter + $diff" | bc)
        fi
        prev=$val
    done
    jitter=$(fmt "$jitter / ($trimmed - 1)" 2>/dev/null || echo "0.00")

    echo "$avg|$(fmt "$min / 1")|$(fmt "$max / 1")|$jitter"
}

measure_download() {
    local idx=0 pids=()
    while IFS= read -r url; do
        [[ -z "$url" ]] && continue
        idx=$((idx + 1))
        (
            local out=$(curl -s -o /dev/null -w "%{size_download} %{time_total}" --max-time "$DOWNLOAD_SECONDS" "$url" 2>/dev/null || echo "0 0")
            echo "$out" > "$TMPDIR_ST/dlspeed_${idx}"
        ) &
        pids+=($!)
    done < "$TMPDIR_ST/download_urls"

    for pid in "${pids[@]}"; do wait "$pid" 2>/dev/null || true; done

    local total=0
    for f in "$TMPDIR_ST"/dlspeed_*; do
        [[ -f "$f" ]] || continue
        local line=$(cat "$f" 2>/dev/null || echo "0 0")
        local size=$(echo "$line" | awk '{print $1}')
        local time=$(echo "$line" | awk '{print $2}')
        if (( $(echo "$time > 0" | bc -l) )); then
            total=$(echo "$total + $size * 8 / $time" | bc)
        fi
    done
    echo "$total"
}

measure_upload() {
    local idx=0 pids=()
    while IFS= read -r url; do
        [[ -z "$url" ]] && continue
        idx=$((idx + 1))
        (
            local data="$TMPDIR_ST/upload_data_${idx}"
            dd if=/dev/urandom bs=1M count=10 of="$data" 2>/dev/null
            local out=$(curl -s -o /dev/null -w "%{size_upload} %{time_total}" --max-time "$UPLOAD_SECONDS" -F "file=@$data" "$url" 2>/dev/null || echo "0 0")
            echo "$out" > "$TMPDIR_ST/ulspeed_${idx}"
        ) &
        pids+=($!)
    done < "$TMPDIR_ST/upload_urls"

    for pid in "${pids[@]}"; do wait "$pid" 2>/dev/null || true; done

    local total=0
    for f in "$TMPDIR_ST"/ulspeed_*; do
        [[ -f "$f" ]] || continue
        local line=$(cat "$f" 2>/dev/null || echo "0 0")
        local size=$(echo "$line" | awk '{print $1}')
        local time=$(echo "$line" | awk '{print $2}')
        if (( $(echo "$time > 0" | bc -l) )); then
            total=$(echo "$total + $size * 8 / $time" | bc)
        fi
    done
    echo "$total"
}

save_history() {
    mkdir -p "$CONFIG_DIR"
    if [[ ! -f "$HISTORY_FILE" ]]; then
        echo "timestamp,download_bps,upload_bps,ping_ms" > "$HISTORY_FILE"
    fi
    echo "$(date +%Y-%m-%d\ %H:%M:%S),$1,$2,$3" >> "$HISTORY_FILE"
}

show_history() {
    if [[ ! -f "$HISTORY_FILE" ]]; then
        echo -e "${YELLOW}No test history yet. Run some tests first!${RESET}"
        return
    fi
    echo ""
    echo -e "  ${BOLD}${CYAN}════════════════════════════════════════${RESET}"
    echo -e "  ${BOLD}TEST HISTORY${RESET}"
    echo -e "  ${DIM}────────────────────────────────────${RESET}"
    tail -n 10 "$HISTORY_FILE" | column -t -s ',' | while read line; do
        echo "  $line"
    done
    echo -e "  ${CYAN}════════════════════════════════════════${RESET}"
    echo ""
}

print_connection_info() {
    if $JSON_OUTPUT || $QUIET_MODE; then
        return
    fi
    echo ""
    echo -e "  ${BOLD}${CYAN}════════════════════════════════════════${RESET}"
    echo -e "  ${BOLD}CONNECTION INFO${RESET}"
    echo -e "  ${DIM}────────────────────────────────────${RESET}"
    echo -e "  ${DIM}IPv4:${RESET}      ${GREEN}${CONN_IPV4:-N/A}${RESET}"
    if [[ -n "${CONN_IPV6:-}" ]] && [[ "${CONN_IPV6}" != "N/A" ]]; then
        echo -e "  ${DIM}IPv6:${RESET}      ${CYAN}${CONN_IPV6}${RESET}"
    else
        echo -e "  ${DIM}IPv6:${RESET}      ${DIM}not available${RESET}"
    fi
    [[ "${CONN_ORG:-N/A}" != "N/A" ]] && echo -e "  ${DIM}ISP:${RESET}       ${YELLOW}${CONN_ORG}${RESET}"
    
    local location=""
    [[ -n "${CONN_CITY:-}" ]] && [[ "${CONN_CITY}" != "N/A" ]] && location="${CONN_CITY}"
    [[ -n "${CONN_REGION:-}" ]] && location="${location}${location:+, }${CONN_REGION}"
    [[ -n "${CONN_COUNTRY:-}" ]] && location="${location}${location:+, }${CONN_COUNTRY}"
    
    if [[ -n "$location" ]]; then
        echo -e "  ${DIM}Location:${RESET}   ${WHITE}${location}${RESET}"
    fi
    echo -e "  ${CYAN}════════════════════════════════════════${RESET}"
    echo ""
}

# =============================================================================
# MAIN
# =============================================================================

main() {
    if $SHOW_HISTORY; then
        show_history
        exit 0
    fi

    print_header

    # Check dependencies
    (
        for cmd in curl bc python3; do
            if ! command -v "$cmd" >/dev/null 2>&1; then
                echo "Missing: $cmd" >&2
                exit 1
            fi
        done
    ) &
    spinner $! "Checking dependencies"

    # Fetch probes
    (
        fetch_probes
    ) &
    spinner $! "Fetching servers"

    # Get connection info
    (
        get_connection_info
    ) &
    spinner $! "Getting connection info"
    
    wait
    
    # Show connection info
    print_connection_info

    # Measure ping
    (
        PING_RESULT=$(measure_ping)
    ) &
    spinner $! "Measuring ping"
    
    IFS='|' read -r ping_avg ping_min ping_max ping_jitter <<< "$PING_RESULT"

    if ! $JSON_OUTPUT && ! $QUIET_MODE; then
        echo ""
        printf "  ${BOLD}Ping:${RESET} ${WHITE}%.2f ms${RESET} ${DIM}(min: %.2f / max: %.2f / jitter: %.2f)${RESET}\n" \
            "$ping_avg" "$ping_min" "$ping_max" "$ping_jitter"
        echo ""
    fi

    # Measure download
    (
        DOWNLOAD=$(measure_download)
    ) &
    spinner $! "Download"

    # Measure upload
    (
        UPLOAD=$(measure_upload)
    ) &
    spinner $! "Upload"

    wait

    # Save to history
    save_history "$DOWNLOAD" "$UPLOAD" "$ping_avg"

    # Output results
    if $JSON_OUTPUT; then
        cat << EOF
{
  "version": "$VERSION",
  "timestamp": "$(date -Iseconds)",
  "connection": {
    "ipv4": "${CONN_IPV4:-null}",
    "ipv6": ${CONN_IPV6:+\"$CONN_IPV6\"}${CONN_IPV6:-null},
    "isp": "${CONN_ORG:-}"
  },
  "results": {
    "download": {
      "bps": $DOWNLOAD,
      "human": "$(format_speed "$DOWNLOAD")"
    },
    "upload": {
      "bps": $UPLOAD,
      "human": "$(format_speed "$UPLOAD")"
    },
    "ping": {
      "average": $ping_avg,
      "minimum": $ping_min,
      "maximum": $ping_max,
      "jitter": $ping_jitter
    }
  }
}
EOF
    else
        echo ""
        echo -e "  ${BOLD}${CYAN}╔════════════════════════════════════════╗${RESET}"
        echo -e "  ${BOLD}${CYAN}║         SPEED TEST RESULTS            ║${RESET}"
        echo -e "  ${BOLD}${CYAN}╠════════════════════════════════════════╣${RESET}"
        
        local download_emoji=$(get_speed_emoji "$DOWNLOAD")
        local upload_emoji=$(get_speed_emoji "$UPLOAD")
        
        printf "  ${CYAN}║${RESET}  %s ${BOLD}%-8s${RESET}  ${GREEN}%12s${RESET}  %5s${CYAN}║${RESET}\n" \
            "$download_emoji" "Download" "$(format_speed "$DOWNLOAD")" ""
        printf "  ${CYAN}║${RESET}  %s ${BOLD}%-8s${RESET}  ${YELLOW}%12s${RESET}  %5s${CYAN}║${RESET}\n" \
            "$upload_emoji" "Upload" "$(format_speed "$UPLOAD")" ""
        echo -e "  ${BOLD}${CYAN}╚════════════════════════════════════════╝${RESET}"
        echo ""
        
        # Show random tip
        local tips=(
            "Use --json for JSON output"
            "View history with --history"
            "Quiet mode with --quiet"
        )
        local idx=$((RANDOM % ${#tips[@]}))
        echo -e "  ${DIM}💡 Tip: ${tips[$idx]}${RESET}"
        echo ""
    fi
}

main "$@"
