#!/bin/bash

# =============================================================================
# DataCheap Speed Test v2.0
# Mescheryakov & Romanov Industries
# =============================================================================

set -euo pipefail

# =============================================================================
# COLOR SYSTEM (with tput fallback)
# =============================================================================

if command -v tput >/dev/null 2>&1 && tput setaf 1 >/dev/null 2>&1; then
    # 256 colors available
    RED=$(tput setaf 196)
    GREEN=$(tput setaf 82)
    YELLOW=$(tput setaf 226)
    BLUE=$(tput setaf 39)
    MAGENTA=$(tput setaf 201)
    CYAN=$(tput setaf 51)
    ORANGE=$(tput setaf 208)
    PURPLE=$(tput setaf 129)
    WHITE=$(tput setaf 255)
    GRAY=$(tput setaf 244)
    BOLD=$(tput bold)
    DIM=$(tput dim)
    REVERSE=$(tput rev)
    BLINK=$(tput blink)
    RESET=$(tput sgr0)
else
    # Fallback to ANSI
    RED='\033[0;31m'; GREEN='\033[0;32m'; YELLOW='\033[1;33m'
    BLUE='\033[0;34m'; MAGENTA='\033[0;35m'; CYAN='\033[0;36m'
    ORANGE='\033[0;33m'; PURPLE='\033[0;35m'; WHITE='\033[1;37m'
    GRAY='\033[1;30m'; BOLD='\033[1m'; DIM='\033[2m'
    REVERSE='\033[7m'; BLINK='\033[5m'; RESET='\033[0m'
fi

# =============================================================================
# CONFIGURATION
# =============================================================================

readonly VERSION="2.0.0"
readonly CONFIG_DIR="$HOME/.config/datacheap-speedtest"
readonly HISTORY_FILE="$CONFIG_DIR/history.csv"
readonly CACHE_DIR="$CONFIG_DIR/cache"

# Test parameters
PING_SAMPLES=10
DOWNLOAD_SECONDS=10
UPLOAD_SECONDS=10
PARALLEL_STREAMS=4

# API endpoints
PROBES_API="https://yandex.ru/internet/api/v0/get-probes"
IPV4_API="https://ipv4-internet.yandex.net/api/v0/ip"
IPV6_API="https://ipv6-internet.yandex.net/api/v0/ip"

# User Agent
UA="Mozilla/5.0 (X11; Linux x86_64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/145.0.0.0 Safari/537.36"

# =============================================================================
# COMMAND LINE ARGUMENTS
# =============================================================================

MODE="normal"
SELECTED_SERVER=""
JSON_OUTPUT=false
QUIET_MODE=false
DEBUG_MODE=false
SHOW_HISTORY=false

show_usage() {
    cat << EOF
${BOLD}${CYAN}DataCheap Speed Test v${VERSION}${RESET}
${DIM}Mescheryakov & Romanov Industries${RESET}

${BOLD}Usage:${RESET} $0 [OPTIONS]

${BOLD}Options:${RESET}
  ${GREEN}-s, --server${RESET} [ID]    Select specific server
  ${GREEN}-j, --json${RESET}           Output in JSON format
  ${GREEN}-h, --history${RESET}        Show test history
  ${GREEN}-q, --quiet${RESET}          Minimal output mode
  ${GREEN}-d, --debug${RESET}          Enable debug mode
  ${GREEN}--help${RESET}                Show this help message

${BOLD}Examples:${RESET}
  $0                    Run speed test
  $0 --json            JSON output for scripts
  $0 --history         View test history
  $0 --server 2        Use specific server
EOF
    exit 0
}

parse_args() {
    while [[ $# -gt 0 ]]; do
        case $1 in
            -s|--server)
                SELECTED_SERVER="$2"
                shift 2
                ;;
            -j|--json)
                JSON_OUTPUT=true
                shift
                ;;
            -q|--quiet)
                QUIET_MODE=true
                shift
                ;;
            -d|--debug)
                DEBUG_MODE=true
                shift
                ;;
            -h|--history)
                SHOW_HISTORY=true
                shift
                ;;
            --help)
                show_usage
                ;;
            *)
                echo "${RED}Unknown option: $1${RESET}"
                show_usage
                ;;
        esac
    done
}

# =============================================================================
# UTILITY FUNCTIONS
# =============================================================================

debug_log() {
    if $DEBUG_MODE; then
        echo "${DIM}[DEBUG]${RESET} $*" >&2
    fi
}

init_dirs() {
    mkdir -p "$CONFIG_DIR" "$CACHE_DIR"
}

cleanup() {
    if [[ -n "${TMPDIR_ST:-}" ]] && [[ -d "$TMPDIR_ST" ]]; then
        rm -rf "$TMPDIR_ST" 2>/dev/null
    fi
    kill $(jobs -p) 2>/dev/null || true
}

trap cleanup EXIT

fmt_float() {
    printf "%.2f" "$(echo "scale=4; $1" | bc 2>/dev/null || echo "0")"
}

format_speed() {
    local bps=$1
    if (( $(echo "$bps >= 1000000000" | bc -l) )); then
        echo "$(fmt_float "$bps / 1000000000") Gbit/s"
    elif (( $(echo "$bps >= 1000000" | bc -l) )); then
        echo "$(fmt_float "$bps / 1000000") Mbit/s"
    elif (( $(echo "$bps >= 1000" | bc -l) )); then
        echo "$(fmt_float "$bps / 1000") Kbit/s"
    else
        echo "$(printf "%.0f" "$(echo "$bps" | bc)") bit/s"
    fi
}

get_speed_emoji() {
    local speed=$1
    if (( $(echo "$speed >= 1000000000" | bc -l) )); then
        echo "рџљЂ"
    elif (( $(echo "$speed >= 500000000" | bc -l) )); then
        echo "вљЎ"
    elif (( $(echo "$speed >= 100000000" | bc -l) )); then
        echo "рџ“Ў"
    else
        echo "рџђў"
    fi
}

# =============================================================================
# UI COMPONENTS
# =============================================================================

